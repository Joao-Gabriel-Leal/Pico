{
  "name": "picomap",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "concurrently \"node --watch backend/server.js\" \"vite --host 127.0.0.1\"",
    "dev:client": "vite --host 127.0.0.1",
    "dev:server": "node --watch backend/server.js",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "start": "node backend/server.js",
    "start:server": "node backend/server.js",
    "db:migrate": "node database/migrate.js",
    "db:seed": "node database/seed.js",
    "db:setup": "npm run db:migrate && npm run db:seed",
    "db:clear-demo": "node database/clear-demo.js"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.0",
    "express": "^5.2.1",
    "leaflet": "^1.9.4",
    "multer": "^2.1.1",
    "pg": "^8.20.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.14.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "vite": "^7.0.0"
  }
}
